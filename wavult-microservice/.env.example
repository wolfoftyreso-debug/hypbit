# ---- Service ---------------------------------------------------------------
NODE_ENV=development
SERVICE_NAME=wavult-microservice
SERVICE_VERSION=1.0.0
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_MS=15000

# ---- Postgres --------------------------------------------------------------
DATABASE_URL=postgres://wavult:wavult@localhost:5432/wavult
DATABASE_POOL_MAX=20
DATABASE_SSL=false

# ---- Redis -----------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=wavult:

# ---- Kafka -----------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=wavult-microservice
KAFKA_GROUP_ID=wavult-microservice-consumer
KAFKA_TOPIC_EVENTS=wavult.events.v1
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ---- AWS -------------------------------------------------------------------
AWS_REGION=eu-north-1
AWS_S3_BUCKET=wavult-events
AWS_SQS_QUEUE_URL=
AWS_SECRETS_MANAGER_ID=

# ---- Observability ---------------------------------------------------------
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
METRICS_ENABLED=true

# ---- Security --------------------------------------------------------------
API_KEY=change-me-in-secrets-manager
CORS_ORIGIN=*
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
