### Wavult Geopol — environment

# App
NODE_ENV=production
CORS_ORIGIN=*
WEB_PORT=8080
OUR_NODE_ID=our_node

# Neo4j (external)
NEO4J_URI=bolt://neo4j.internal:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# Redis (external)
REDIS_URL=redis://redis.internal:6379

# OpenSearch (external)
OPENSEARCH_URL=https://opensearch.internal:9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=

# Kafka (external — MSK, Confluent, self-hosted…)
KAFKA_BROKERS=kafka.internal:9092
KAFKA_ENABLED=true

# Influence Ingestion
INGESTION_POLL_MS=60000
INGESTION_RSS_FEEDS=https://news.google.com/rss,https://www.reuters.com/rssFeed/technology
INGESTION_USE_MOCK=true

# Influence Enrichment (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
COMPANY_CONTEXT=Wavult builds an influence intelligence platform. We depend on AWS, Azure and AI model providers, and we care about EU tech regulation.

# Relation Discovery
DISCOVERY_SCHEDULE_MS=3600000
DISCOVERY_TOP_N=20

# Frontend build
VITE_API_PROXY=http://localhost:4000
VITE_MAPBOX_TOKEN=
