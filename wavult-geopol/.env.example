### Wavult Geopol environment

# App
NODE_ENV=production
CORS_ORIGIN=*
CLIENT_PORT=8080

# Neo4j (external)
NEO4J_URI=bolt://neo4j.internal:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# Redis (external)
REDIS_URL=redis://redis.internal:6379

# OpenSearch (external)
OPENSEARCH_URL=https://opensearch.internal:9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
