NODE_ENV=development

# ---- Postgres --------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=amos
POSTGRES_PASSWORD=amos
POSTGRES_DB=amos

# ---- Redis -----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Kafka -----------------------------------------------------------------
KAFKA_BROKERS=kafka:29092
KAFKA_CLIENT_ID_PREFIX=amos

# ---- S3 / MinIO ------------------------------------------------------------
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=amosminio
S3_SECRET_KEY=amosminio-secret
S3_BUCKET=amos-identity
S3_FORCE_PATH_STYLE=true

# ---- Crypto ----------------------------------------------------------------
# 32 bytes (hex) — override in prod with Secrets Manager
PII_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
JWT_ISSUER=amos-identity
JWT_AUDIENCE=amos-external

# ---- External providers ----------------------------------------------------
COMPREFACE_URL=http://compreface-api:8080
COMPREFACE_API_KEY=replace-me
TESSERACT_LANG=eng+swe

# ---- Service ports ---------------------------------------------------------
IDENTITY_SERVICE_PORT=3000
DOCUMENT_SERVICE_PORT=3001
FACE_SERVICE_PORT=3002
RISK_SERVICE_PORT=3003
AUDIT_SERVICE_PORT=3004

LOG_LEVEL=info
