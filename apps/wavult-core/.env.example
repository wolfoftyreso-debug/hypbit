# wavult-core — Miljövariabler
# Kopiera till .env.local för lokal development
# Produktionsvärden hanteras via AWS SSM Parameter Store (ej i kod)

# ── DATABASE ──────────────────────────────────────────────────────────────────
# REGEL: SUPABASE_URL ska ALLTID vara intern URL — aldrig *.supabase.co
# Migration 2026-04-04: Cloud Supabase → Wavult OS egna RDS (wavult-identity-ecs)
# Prod-URL hämtas via: aws ssm get-parameter --name /wavult/prod/WAVULT_OS_DB_URL --with-decryption
#
# ⛔ FÖRBJUDET: SUPABASE_URL=https://znmxtnxxjpmgtycmsqjv.supabase.co
# ✅ KORREKT:   SUPABASE_URL=<intern self-hosted supabase URL eller PostgreSQL-URL>
#
SUPABASE_URL=          # Intern URL — ALDRIG *.supabase.co (cloud blockeras av lib/db.ts)
SUPABASE_SERVICE_KEY=  # Service role key för intern Supabase (om självhostad) eller lämna tom
DATABASE_URL=          # Direkt PostgreSQL-URL: postgresql://user:pass@host:5432/dbname?sslmode=require

# ── AUTH ──────────────────────────────────────────────────────────────────────
JWT_SECRET=            # JWT-signeringsnyckel (min 256-bit)

# ── VOICE (46elks + ElevenLabs + Whisper) ────────────────────────────────────
FORTYSIX_ELKS_USERNAME=
FORTYSIX_ELKS_PASSWORD=
FORTYSIX_ELKS_NUMBER=  # +46766862613
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=   # Default: EXAVITQu4vr4xnSDxMaL (Sarah)
PUBLIC_BASE_URL=       # https://api.wavult.com

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLAMA_HOST=http://localhost:11434         # Ollama endpoint — Llama 4 Scout på EC2 g4dn.xlarge

# ── INFRASTRUKTUR ─────────────────────────────────────────────────────────────
PORT=3000
REDIS_URL=redis://localhost:6379
